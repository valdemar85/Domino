<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Uses MaterialComponents for cards / buttons / dialogs.
         NoActionBar — we provide our own MaterialToolbar at the top of the layout. -->
    <style name="Theme.Domino" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/domino_primary</item>
        <item name="colorPrimaryVariant">@color/domino_primary_dark</item>
        <item name="colorOnPrimary">@color/domino_on_primary</item>

        <item name="colorSecondary">@color/domino_secondary</item>
        <item name="colorSecondaryVariant">@color/domino_secondary_dark</item>
        <item name="colorOnSecondary">@color/domino_on_surface</item>

        <item name="colorSurface">@color/domino_surface</item>
        <item name="colorOnSurface">@color/domino_on_surface</item>
        <item name="android:colorBackground">@color/domino_background</item>
        <item name="colorError">@color/domino_error</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/domino_primary_dark</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/domino_background</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Domino.Dialog</item>
        <item name="materialButtonStyle">@style/Widget.Domino.Button</item>
    </style>

    <style name="Widget.Domino.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Domino.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Domino.Button.Destructive" parent="Widget.Domino.Button.Outlined">
        <item name="strokeColor">@color/domino_error</item>
        <item name="android:textColor">@color/domino_error</item>
        <item name="rippleColor">@color/domino_error</item>
    </style>

    <style name="Widget.Domino.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/domino_surface</item>
    </style>

    <style name="ThemeOverlay.Domino.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/domino_primary</item>
        <!-- Dialog surface intentionally distinct from card surface so popups stand out
             on top of the white card stack visually. -->
        <item name="colorSurface">@color/domino_dialog_surface</item>
        <item name="alertDialogStyle">@style/MaterialAlertDialog.Domino</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MaterialAlertDialog.Domino.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/MaterialAlertDialog.Domino.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Domino.Dialog.PositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Domino.Dialog.NegativeButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Domino.Dialog.NeutralButton</item>
    </style>

    <style name="MaterialAlertDialog.Domino" parent="MaterialAlertDialog.MaterialComponents">
        <item name="shapeAppearance">@style/ShapeAppearance.Domino.Dialog</item>
        <item name="backgroundTint">@color/domino_dialog_surface</item>
    </style>

    <style name="ShapeAppearance.Domino.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="MaterialAlertDialog.Domino.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/domino_primary_dark</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MaterialAlertDialog.Domino.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/domino_on_surface</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.Domino.Dialog.PositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/domino_success</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Domino.Dialog.NegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/domino_error</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Domino.Dialog.NeutralButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/domino_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
